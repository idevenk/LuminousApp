<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/purple_bg"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- CONNECT BUTTON -->
    <Button
        android:id="@+id/btnConnect"
        android:text="CONNECT"
        android:textColor="@color/text_white"
        android:backgroundTint="@color/purple_primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- QUOTE -->
    <TextView
        android:id="@+id/txtQuote"
        android:text="Stay luminous."
        android:textColor="@color/purple_accent"
        android:textSize="18sp"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- SWITCH -->
    <Switch
        android:id="@+id/switchLamp"
        android:text="Lamp ON/OFF"
        android:textColor="@color/text_white"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- SLIDER -->
    <SeekBar
        android:id="@+id/seekBrightness"
        android:max="255"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- CHAT PLACEHOLDER -->
    <TextView
        android:text="Community Chat (Coming Soon)"
        android:textColor="@color/purple_accent"
        android:layout_marginTop="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>
